# JARVIS optional environment configuration
# Copy this file to .env and fill in the values you want.
#
# Two LLM backends are supported, picked from LLM_PROVIDER:
#   * gemini  - native google-genai SDK (best for Google AI Studio keys)
#   * openai  - any OpenAI-compatible Chat Completions API
#
# Examples:
#
#   ---- Google Gemini (key from https://aistudio.google.com) ----
#   LLM_PROVIDER=gemini
#   GEMINI_API_KEY=AIza...
#   GEMINI_MODEL=gemini-2.5-flash
#
#   ---- OpenAI ----
#   LLM_PROVIDER=openai
#   OPENAI_API_KEY=sk-...
#   OPENAI_BASE_URL=https://api.openai.com/v1
#   OPENAI_MODEL=gpt-4o-mini
#
#   ---- Groq ----
#   LLM_PROVIDER=openai
#   OPENAI_API_KEY=gsk_...
#   OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   OPENAI_MODEL=llama-3.1-70b-versatile

LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Gemini-specific (used when LLM_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
